[scanner]
db_path = "./data/pscanner.sqlite3"
log_level = "INFO"

[smart_money]
enabled = true
leaderboard_top_n = 200
min_resolved_positions = 20
min_edge = 0.05
min_excess_pnl_usd = 1000.0
refresh_interval_seconds = 3600
position_poll_interval_seconds = 300
new_position_min_usd = 1000
prewarm_event_tag_cache = true
# Per-category min-edge thresholds live in
# `pscanner.categories.DEFAULT_TAXONOMY`. Uncomment below to override one or
# more categories at runtime (keys are Category string values):
# [smart_money.category_min_edge]
# thesis = 0.05
# sports = 0.10
# esports = 0.05

[mispricing]
enabled = true
scan_interval_seconds = 300
sum_deviation_threshold = 0.03
alert_max_deviation = 0.5
min_event_liquidity_usd = 10000
min_market_liquidity_usd = 100
max_market_count = 8
# Category-based exclusion (sports/esports) is sourced from
# `pscanner.categories.DEFAULT_TAXONOMY` via the `mispricing_skip` flag and
# is not configurable here.

[whales]
enabled = true
new_account_max_age_days = 30
new_account_max_trades = 50
small_market_max_liquidity_usd = 50000
big_bet_min_pct_of_liquidity = 0.05
big_bet_min_usd = 2000
ws_resubscribe_interval_seconds = 1800
subscription_max_markets = 2000
subscription_min_volume_usd = 100

[convergence]
enabled = true
convergence_min_wallets = 2
# Per-category convergence windows live in
# `pscanner.categories.DEFAULT_TAXONOMY`. Uncomment below to override one or
# more categories at runtime (keys are Category string values):
# [convergence.window_seconds_overrides]
# thesis = 172800
# sports = 21600
# esports = 86400

[ratelimit]
gamma_rpm = 50
data_rpm = 50

[positions]
enabled = true
snapshot_interval_seconds = 300

[activity]
enabled = true
poll_interval_seconds = 300
activity_page_limit = 200
max_pages = 10
dup_lookback = 50

[markets]
enabled = true
snapshot_interval_seconds = 300
snapshot_max = 5000

[events]
enabled = true
snapshot_interval_seconds = 900
snapshot_max = 2000

[ticks]
enabled = true
tick_interval_seconds = 30
subscription_refresh_seconds = 300
tick_volume_floor_usd = 10000
max_assets = 1000

[velocity]
enabled = true
velocity_threshold_pct = 0.05
velocity_window_seconds = 60
poll_interval_seconds = 5
depth_asymmetry_floor = 0.05
min_mid_liquidity_usd = 100
spread_compression_floor = 5

[cluster]
enabled = true
scan_interval_seconds = 3600
discovery_lookback_days = 30
creation_window_seconds = 86400
min_cluster_size = 3
min_shared_markets = 3
max_shared_market_liquidity_usd = 50000
max_shared_market_volume_usd = 1000000
max_trade_size_cv = 0.3
direction_window_seconds = 600
min_direction_correlation_count = 3
discovery_score_threshold = 5
active_window_seconds = 300
active_min_members = 2
