[scanner]
db_path = "./data/pscanner.sqlite3"
log_level = "INFO"

[smart_money]
enabled = true
leaderboard_top_n = 200
min_resolved_positions = 20
min_edge = 0.05
min_excess_pnl_usd = 1000.0
refresh_interval_seconds = 3600
position_poll_interval_seconds = 300
new_position_min_usd = 1000
prewarm_event_tag_cache = true

[smart_money.category_min_edge]
thesis = 0.05
sports = 0.10
esports = 0.05

[mispricing]
enabled = true
scan_interval_seconds = 300
sum_deviation_threshold = 0.03
alert_max_deviation = 0.5
min_event_liquidity_usd = 10000
min_market_liquidity_usd = 100
excluded_tags = ["Sports", "Esports"]

[whales]
enabled = true
new_account_max_age_days = 30
new_account_max_trades = 50
small_market_max_liquidity_usd = 50000
big_bet_min_pct_of_liquidity = 0.05
big_bet_min_usd = 2000
ws_resubscribe_interval_seconds = 1800
subscription_max_markets = 2000
subscription_min_volume_usd = 100

[convergence]
enabled = true
convergence_min_wallets = 2
window_seconds_thesis = 172800
window_seconds_sports = 21600
window_seconds_esports = 86400

[ratelimit]
gamma_rpm = 50
data_rpm = 50

[positions]
enabled = true
snapshot_interval_seconds = 300

[activity]
enabled = true
poll_interval_seconds = 300
activity_page_limit = 200
max_pages = 10
dup_lookback = 50

[markets]
enabled = true
snapshot_interval_seconds = 300
snapshot_max = 5000

[events]
enabled = true
snapshot_interval_seconds = 900
snapshot_max = 2000

[ticks]
enabled = true
tick_interval_seconds = 30
subscription_refresh_seconds = 300
tick_volume_floor_usd = 10000
max_assets = 1000

[velocity]
enabled = true
velocity_threshold_pct = 0.05
velocity_window_seconds = 60
poll_interval_seconds = 5
depth_asymmetry_floor = 0.05
min_mid_liquidity_usd = 100
